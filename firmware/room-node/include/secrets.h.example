/*
 * Secrets Configuration Template for Room Node
 *
 * INSTRUCTIONS:
 * 1. Copy this file to: include/secrets.h
 *      cp include/secrets.h.example include/secrets.h
 * 2. Fill in your WiFi credentials and backend IP address.
 * 3. NEVER commit secrets.h to git (it is listed in .gitignore).
 *
 * One copy of secrets.h is needed per ESP32.  The only field that
 * differs between the three room nodes is DEVICE_ROOM_ID (see config.h).
 */

#ifndef SECRETS_H
#define SECRETS_H

// WiFi Credentials
#define WIFI_SSID     "YourNetworkName"
#define WIFI_PASSWORD "YourNetworkPassword"

// Backend API / WebSocket host (IP address of the machine running the backend)
// Example: "192.168.1.100"
#define API_HOST "192.168.1.100"

#endif // SECRETS_H

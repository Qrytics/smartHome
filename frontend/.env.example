# Backend API base URL (no trailing /api/v1)
REACT_APP_API_URL=http://localhost:8000

# Production / Pi: set to true so API and WS use the same hostname as the page (port 8000).
# Leave unset for normal local dev (uses REACT_APP_API_URL above).
# REACT_APP_USE_BROWSER_ORIGIN=true

# Optional explicit WebSocket URL (if unset, derived from REACT_APP_API_URL)
# Example: ws://localhost:8000/ws/client
REACT_APP_WS_URL=

# Dashboard admin session credentials (frontend management session)
REACT_APP_ADMIN_USERNAME=admin
REACT_APP_ADMIN_PASSWORD=changeme

# Environment label
REACT_APP_ENV=development

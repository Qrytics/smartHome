# Used automatically by `npm run build` (Create React App production build).
# Copy to .env.production on the Pi.
#
# Recommended (LAN demo): derive API + WebSocket from the same hostname as the dashboard
# so http://smartHome:3000 and http://192.168.x.x:3000 both talk to the backend on :8000.
REACT_APP_USE_BROWSER_ORIGIN=true
#
# If USE_BROWSER_ORIGIN is not set, set explicit URLs reachable from the browser (not localhost):
# REACT_APP_API_URL=http://172.26.249.249:8000
# REACT_APP_WS_URL=ws://172.26.249.249:8000/ws/client

REACT_APP_ADMIN_USERNAME=admin
REACT_APP_ADMIN_PASSWORD=changeme
REACT_APP_ENV=production
